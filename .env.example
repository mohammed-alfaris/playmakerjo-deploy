# PlayMaker JO Production Environment Variables
# Copy this to .env on the server and fill in real values.
# NEVER commit the .env file to git!

# MySQL
MYSQL_ROOT_PASSWORD=CHANGE_ME_strong_random_password

# JWT — generate with: openssl rand -base64 48
JWT_SECRET_KEY=CHANGE_ME_min_32_chars_random_key

# URLs
UPLOADS_BASE_URL=https://api.playmakerjo.com
CORS_ORIGINS=https://admin.playmakerjo.com
