# ═══════════════════════════════════════════════════════════
# PlayMaker JO — Root .gitignore
# ═══════════════════════════════════════════════════════════

# ── Secrets (NEVER commit) ──
.env
*.env.local
**/firebase-credentials.json
firebase-credentials.json

# ── ASP.NET Core secrets/build ──
sports-venue-api/SportsVenueApi/appsettings.Development.json
sports-venue-api/SportsVenueApi/appsettings.Production.json
**/bin/
**/obj/
*.user
*.suo

# ── Node.js / Vite (React dashboard) ──
**/node_modules/
**/dist/
**/.vite/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/

# ── Flutter / Dart (mobile app) ──
**/.dart_tool/
**/.flutter-plugins
**/.flutter-plugins-dependencies
**/.packages
**/.pub-cache/
**/.pub/
**/build/
**/.flutter/
**/generated_plugin_registrant.*
**/pubspec.lock.bak

# Flutter platform-specific build outputs
**/android/.gradle/
**/android/app/build/
**/android/build/
**/android/local.properties
**/android/key.properties
**/android/*.jks
**/android/*.keystore
**/android/app/release/
**/android/captures/
**/android/gradlew
**/android/gradlew.bat
**/android/.kotlin/

**/ios/Pods/
**/ios/.symlinks/
**/ios/Flutter/Flutter.framework
**/ios/Flutter/Flutter.podspec
**/ios/Flutter/App.framework
**/ios/Flutter/flutter_assets/
**/ios/Flutter/Generated.xcconfig
**/ios/Flutter/ephemeral/
**/ios/Runner/GeneratedPluginRegistrant.*
**/ios/ServiceDefinitions.json
**/ios/*.mode1v3
**/ios/*.mode2v3
**/ios/*.moved-aside
**/ios/*.pbxuser
**/ios/*.perspectivev3
**/ios/xcuserdata/

**/macos/Pods/
**/macos/Flutter/ephemeral/
**/macos/Flutter/GeneratedPluginRegistrant.*
**/macos/xcuserdata/

**/linux/flutter/ephemeral/
**/windows/flutter/ephemeral/

# ── Database & backups ──
backups/
*.sql.gz
*.db

# ── OS files ──
.DS_Store
Thumbs.db
desktop.ini

# ── IDE / Editor ──
.vs/
.vscode/
.idea/
*.iml
*.swp
*.swo
*~
.history/

# ── Logs ──
logs/
*.log

# ── Coverage ──
coverage/
*.lcov

# ── Screenshot dev artifacts (not product) ──
screenshot_*.png
/TEST.md
